# =============================================================================
# Prince Photography — local dev environment variables
#
# Copy this file to `.env.local` and fill in the real values.
# `.env.local` is gitignored — never commit real secrets.
# =============================================================================

# --- Cloudinary (image storage) ---------------------------------------------
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# --- Admin JWT signing secret (min 32 chars, random) ------------------------
# Generate via PowerShell:
#   [Convert]::ToBase64String((1..48 | % { Get-Random -Min 0 -Max 256 }))
JWT_SECRET=replace_with_long_random_string

# --- Cloudflare Turnstile (CAPTCHA on inquiry form) -------------------------
TURNSTILE_SECRET_KEY=your_turnstile_secret
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your_turnstile_site_key

# --- Resend (transactional email) -------------------------------------------
RESEND_API_KEY=re_your_resend_api_key

# --- Email addresses --------------------------------------------------------
# ADMIN_EMAIL receives new inquiry notifications.
# FROM_EMAIL is what customers see as the sender. Must be a verified Resend
# domain, OR use onboarding@resend.dev for testing.
ADMIN_EMAIL=sharon.augustin2@gmail.com
FROM_EMAIL=Prince Photography <onboarding@resend.dev>
